# Canton DEX — Frontend Environment Variables
# Copy this file to .env.local and fill in the values.

# Default wallet provider selection: production builds never default to
# the operator relay. The default is, in order: PartyLayer (if
# VITE_ENABLE_PARTYLAYER=1), then WalletConnect (if VITE_WC_PROJECT_ID is set),
# then SDK (if VITE_ENABLE_SDK=1); otherwise the user must pick a provider
# explicitly. The operator relay (token-standard) is the default only in dev
# builds and is labelled "dev only".

# Reown / WalletConnect Cloud project ID (required for WalletConnect provider).
# Get one at https://cloud.reown.com
VITE_WC_PROJECT_ID=

# Enable the CIP-0103 SDK wallet provider.
VITE_ENABLE_SDK=0

# CIP-103 wallet gateway the SDK provider connects to (Splice LocalNet validator
# Amulet wallet gateway). Shown as the "Gateway" row in the auto-detect picker.
# Default: http://localhost:3030/api/v0/dapp
VITE_WALLET_GATEWAY_URL=
# Display name for that gateway row (default: "Canton wallet gateway").
VITE_WALLET_GATEWAY_NAME=

# Wallet picker: auto-detects the wallets available in this deployment
# (SDK gateway + injected/announced browser wallets + PartyLayer's catalog) and
# shows them in one list. Set to 1 to ALSO list PartyLayer catalog wallets that
# report not-installed (greyed rows with an install link); default hides them.
VITE_WALLET_SHOW_FULL_CATALOG=0

# CAIP network identifier for Canton (default: canton:devnet).
VITE_CANTON_NETWORK_ID=canton:devnet

# Canton JSON Ledger API URL for direct ledger reads and Token Standard wallet.
VITE_CANTON_LEDGER_URL=http://localhost:7575

# Bearer token for the dev-only Token Standard relay / canton-direct provider.
# DEV BUILDS ONLY: this is a long-lived credential. It is read only
# when `import.meta.env.DEV` is true; in a production build the app refuses to
# use it (logs an error), and the relay/direct providers that depend on it are
# disabled. Do NOT set this in any production environment.
VITE_CANTON_AUTH_TOKEN=

# Operator backend API base URL (default: http://localhost:8080).
VITE_API_BASE=http://localhost:8080

# Enable the PartyLayer wallet connector in the Connect Wallet menu.
# Requires an installed submit-capable wallet. The DEX tries Console, Nightly,
# then Send by default; include loop to test 5N Loop explicitly.
VITE_ENABLE_PARTYLAYER=0
VITE_PARTYLAYER_APP_NAME=Canton DEX
VITE_PARTYLAYER_NETWORK=canton:devnet
VITE_PARTYLAYER_WALLET_IDS=console,nightly,send
# Example 5N-only wallet selection:
# VITE_PARTYLAYER_WALLET_IDS=loop
# First-time wallet setup can require account/passkey/password steps. Keep the
# connection window alive long enough for that browser round-trip.
VITE_PARTYLAYER_CONNECT_TIMEOUT_MS=180000
# Optional PartyLayer registry overrides.
VITE_PARTYLAYER_REGISTRY_URL=
VITE_PARTYLAYER_REGISTRY_CHANNEL=stable
