# Canton DEX — Frontend Environment Variables
# Copy this file to .env.local and fill in the values.

# Reown / WalletConnect Cloud project ID (required for WalletConnect provider).
# Get one at https://cloud.reown.com
VITE_WC_PROJECT_ID=

# CAIP network identifier for Canton (default: canton:devnet).
VITE_CANTON_NETWORK_ID=canton:devnet

# Canton JSON Ledger API URL for direct ledger reads and Token Standard wallet.
VITE_CANTON_LEDGER_URL=http://localhost:7575

# Bearer token for Token Standard wallet provider (direct Canton auth).
VITE_CANTON_AUTH_TOKEN=

# Operator backend API base URL (default: http://localhost:8080).
VITE_API_BASE=http://localhost:8080

# Enable the PartyLayer wallet connector in the Connect Wallet menu.
# Requires an installed submit-capable wallet. The DEX tries Console, Nightly,
# then Send by default; pin or reorder with VITE_PARTYLAYER_WALLET_IDS.
VITE_ENABLE_PARTYLAYER=0
VITE_PARTYLAYER_APP_NAME=Canton DEX
VITE_PARTYLAYER_NETWORK=canton:devnet
VITE_PARTYLAYER_WALLET_IDS=console,nightly,send
# Optional PartyLayer registry overrides.
VITE_PARTYLAYER_REGISTRY_URL=
VITE_PARTYLAYER_REGISTRY_CHANNEL=stable
