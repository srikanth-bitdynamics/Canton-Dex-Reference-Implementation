# Canton DEX — Operator Backend Environment Variables
# Copy this file to .env and fill in the values.

# --- Canton Ledger Connection ---

# JSON Ledger API base URL (required for production / testnet).
CANTON_LEDGER_URL=http://localhost:7575

# Bearer JWT for the JSON Ledger API.
CANTON_LEDGER_TOKEN=

# JSON Ledger API user id (default: ledger-api-user).
CANTON_USER_ID=ledger-api-user

# --- Party Configuration ---

# Operator party (DEX market venue).
CANTON_OPERATOR=

# LP registrar party (manages LP token lifecycle).
CANTON_LP_REGISTRAR=

# Asset admin party (governs instruments).
CANTON_ADMIN=

# --- Network ---

# Display label for the Canton network (default: canton:devnet).
CANTON_NETWORK=canton:devnet

# Synchronizer id, e.g. global-domain::1220...
CANTON_SYNCHRONIZER=

# Daml package hash or prefix for template ids.
CANTON_DEX_PACKAGE_ID=

# --- Factory Contract IDs ---

# AllocationFactory contract id (from registry bootstrap).
CANTON_ALLOC_FACTORY_CID=

# SettlementFactory contract id (from registry bootstrap).
CANTON_SETTLE_FACTORY_CID=

# --- Server ---

# HTTP server port (default: 8080).
PORT=8080

# SQLite database path for the indexer (default: ./data/operator.db).
DB_PATH=./data/operator.db

# Indexer polling interval in milliseconds (default: 5000).
INDEXER_INTERVAL_MS=5000

# Admin auth token for /v1/admin/* routes. If unset, admin routes are unprotected.
OPERATOR_ADMIN_TOKEN=

# CORS allowed origins (comma-separated). If unset, allows all origins.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173
