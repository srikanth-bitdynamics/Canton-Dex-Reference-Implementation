-- | Proves the delivery-versus-mint/burn mechanism on the V2 allocation
-- surface against the holding-tracking RealRegistry (mirrors upstream
-- TestDeliveryVersusBurnMint): a mint is a leg mintAccount -> recipient
-- (registrar-authorized, owner-None authorizer; settle credits the
-- recipient), a burn is holder -> burnAccount (holder locks; settle archives
-- with no credit).
--
-- AUTHORIZATION CAVEAT (read before trusting "tests pass"): this harness
-- does NOT enforce mint authorization. `RealAllocation` is signatory
-- `admin, authorizerOwner`, and for a mint `authorizerOwner = admin`, so
-- the factory choice runs with the registry's ambient admin authority —
-- nothing here stops a non-admin from exercising the factory to forge a
-- mint allocation (see `testHarnessDoesNotGateMintAuthorization`, which
-- documents exactly that). This is the same class of limitation as
-- MockRegistry's "unsuitable for testing the V2 authorization model"
-- caveat. The happy-path tests below prove the mint/burn *mechanism*
-- (who gets credited / debited), not the authorization model. Real
-- mint authorization lives in the production registry our DEX consumes,
-- not in this shipped test registry — upstream proves it with
-- `TestDeliveryVersusBurnMint`'s `mkAllocMustFail alice adminMintAlloc`.
module CantonDex.Tests.DvpMintBurnTests where

import DA.Assert
import DA.List (head)
import Daml.Script

import Splice.Api.Token.AllocationV2 qualified as V2
import Splice.Api.Token.AllocationInstructionV2 qualified as V2
import Splice.Api.Token.HoldingV2 qualified as V2
import Splice.Api.Token.MetadataV1
import Splice.Testing.Utils (emptyExtraArgs)

import CantonDex.Testing.RealRegistry qualified as RR
import CantonDex.Trading.Utils qualified as Utils

-- Special mint/burn accounts: owner None marks them to the registry.
mintAcct : V2.Account
mintAcct = V2.Account with owner = None; provider = None; id = "mint"

burnAcct : V2.Account
burnAcct = V2.Account with owner = None; provider = None; id = "burn"

-- Lift the instruction result to its completed allocation cid.
completed : V2.AllocationInstructionResult -> ContractId V2.Allocation
completed r = case r.output of
  V2.AllocationInstructionResult_Completed cid -> cid
  _ -> error "allocation must complete immediately"

testDvpMintThenBurn : Script ()
testDvpMintThenBurn = do
  registrar <- allocateParty "registrar"
  alice <- allocateParty "alice"
  now <- getTime

  regCid <- submit registrar $ createCmd RR.RealRegistry with
    admin = registrar
    users = [alice]
  let factoryCid : ContractId V2.AllocationFactory = toInterfaceContractId regCid
      settleCid : ContractId V2.SettlementFactory = toInterfaceContractId regCid
      aliceAcct = Utils.basicAccount alice
      settlement = V2.SettlementInfo with
        executors = [registrar]
        id = "dvp-mint-burn"
        cid = None
        meta = emptyMetadata

  -- ---- MINT 100 LP to alice via DvP ----
  let mintLeg = V2.TransferLeg with
        transferLegId = "mint-lp"
        sender = mintAcct
        receiver = aliceAcct
        amount = 100.0
        instrumentId = "LP"
        meta = emptyMetadata
      mintSpec = V2.AllocationSpecification with
        admin = registrar
        authorizer = mintAcct
        transferLegSides = Utils.legsToSides mintAcct [mintLeg]
        settlementDeadline = None
        nextIterationFunding = None
        committed = False
        meta = emptyMetadata
      receiptSpec = mintSpec with
        authorizer = aliceAcct
        transferLegSides = Utils.legsToSides aliceAcct [mintLeg]

  mintRes <- submit registrar $ exerciseCmd factoryCid V2.AllocationFactory_Allocate with
    settlement; allocation = mintSpec; requestedAt = now
    inputHoldingCids = []; actors = [registrar]; extraArgs = emptyExtraArgs
  receiptRes <- submit alice $ exerciseCmd factoryCid V2.AllocationFactory_Allocate with
    settlement; allocation = receiptSpec; requestedAt = now
    inputHoldingCids = []; actors = [alice]; extraArgs = emptyExtraArgs

  _ <- submit (actAs [registrar, alice]) $
    exerciseCmd settleCid V2.SettlementFactory_SettleBatch with
      settlement
      transferLegs = [mintLeg]
      allocations =
        [ Utils.finalAllocation (completed mintRes)
        , Utils.finalAllocation (completed receiptRes)
        ]
      actors = [registrar]
      extraArgs = emptyExtraArgs

  -- Alice now holds exactly 100 LP, freshly minted.
  aliceLp <- query @RR.RealHolding alice
  let lpHoldings = filter (\(_, h) -> h.instrumentId == "LP" && h.owner == alice && not h.locked) aliceLp
  length lpHoldings === 1
  let (lpCid, lpHolding) = head lpHoldings
  lpHolding.amount === 100.0

  -- ---- BURN the 100 LP via DvP ----
  let burnLeg = V2.TransferLeg with
        transferLegId = "burn-lp"
        sender = aliceAcct
        receiver = burnAcct
        amount = 100.0
        instrumentId = "LP"
        meta = emptyMetadata
      burnSenderSpec = V2.AllocationSpecification with
        admin = registrar
        authorizer = aliceAcct
        transferLegSides = Utils.legsToSides aliceAcct [burnLeg]
        settlementDeadline = None
        nextIterationFunding = None
        committed = False
        meta = emptyMetadata
      burnReceiverSpec = burnSenderSpec with
        authorizer = burnAcct
        transferLegSides = Utils.legsToSides burnAcct [burnLeg]

  burnSenderRes <- submit alice $ exerciseCmd factoryCid V2.AllocationFactory_Allocate with
    settlement; allocation = burnSenderSpec; requestedAt = now
    inputHoldingCids = [toInterfaceContractId lpCid]; actors = [alice]; extraArgs = emptyExtraArgs
  burnReceiverRes <- submit registrar $ exerciseCmd factoryCid V2.AllocationFactory_Allocate with
    settlement; allocation = burnReceiverSpec; requestedAt = now
    inputHoldingCids = []; actors = [registrar]; extraArgs = emptyExtraArgs

  _ <- submit (actAs [registrar, alice]) $
    exerciseCmd settleCid V2.SettlementFactory_SettleBatch with
      settlement
      transferLegs = [burnLeg]
      allocations =
        [ Utils.finalAllocation (completed burnSenderRes)
        , Utils.finalAllocation (completed burnReceiverRes)
        ]
      actors = [registrar]
      extraArgs = emptyExtraArgs

  -- Alice's LP is gone — assert NO LP holding at all (locked or not), so
  -- a holding left locked by a settle that failed to archive would be a
  -- failure, not a false pass. The burn account holds nothing either
  -- (owner None is never credited).
  aliceLpAfter <- query @RR.RealHolding alice
  let lpAfter = filter (\(_, h) -> h.instrumentId == "LP" && h.owner == alice) aliceLpAfter
  length lpAfter === 0

  pure ()

-- Documents the harness limitation called out in the module header: a
-- non-admin can author a mint allocation here because the factory runs
-- with the registry's ambient admin authority. This is NOT desired
-- behaviour — it asserts the gap so it's visible by inspection rather
-- than silently assumed-safe. Production registries gate this via the V2
-- authorization model (upstream: TestDeliveryVersusBurnMint's
-- `mkAllocMustFail alice adminMintAlloc`).
testHarnessDoesNotGateMintAuthorization : Script ()
testHarnessDoesNotGateMintAuthorization = do
  registrar <- allocateParty "registrar"
  mallory <- allocateParty "mallory"
  now <- getTime
  regCid <- submit registrar $ createCmd RR.RealRegistry with
    admin = registrar; users = [mallory]
  let factoryCid : ContractId V2.AllocationFactory = toInterfaceContractId regCid
      settlement = V2.SettlementInfo with
        executors = [registrar]; id = "forge"; cid = None; meta = emptyMetadata
      forgedMintLeg = V2.TransferLeg with
        transferLegId = "forge-mint"; sender = mintAcct
        receiver = Utils.basicAccount mallory; amount = 1000.0
        instrumentId = "LP"; meta = emptyMetadata
      forgedSpec = V2.AllocationSpecification with
        admin = registrar; authorizer = mintAcct
        transferLegSides = Utils.legsToSides mintAcct [forgedMintLeg]
        settlementDeadline = None; nextIterationFunding = None
        committed = False; meta = emptyMetadata
  -- Mallory (a non-admin) authors a mint allocation. In a production
  -- registry this MUST fail; in this harness it succeeds — documenting
  -- that authorization is not enforced here.
  res <- submit mallory $ exerciseCmd factoryCid V2.AllocationFactory_Allocate with
    settlement; allocation = forgedSpec; requestedAt = now
    inputHoldingCids = []; actors = [mallory]; extraArgs = emptyExtraArgs
  case res.output of
    V2.AllocationInstructionResult_Completed _ -> pure ()
    _ -> abort "expected the harness to (permissively) complete the forged mint"
  pure ()
