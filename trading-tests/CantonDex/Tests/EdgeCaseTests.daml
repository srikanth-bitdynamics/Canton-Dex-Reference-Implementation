-- | Rejection paths the end-to-end tests don't cover: zero/negative mint and
-- burn amounts (ensure clauses), and mint-accept failing on instrumentId
-- mismatch or missing issuer credentials.
module CantonDex.Tests.EdgeCaseTests where

import Daml.Script

import CantonDex.Instrument.Burn qualified as Burn
import CantonDex.Instrument.Credentials qualified as Cred
import CantonDex.Instrument.Holding qualified as H
import CantonDex.Instrument.InstrumentConfiguration qualified as IC
import CantonDex.Instrument.Mint qualified as Mint

-- Shared config-creation boilerplate.
mkConfig
  : Party -> Text -> [Cred.CredentialRequirement] -> Text
  -> Script (ContractId IC.InstrumentConfiguration)
mkConfig registrar instrumentId issuerRequirements description =
  submit registrar $ createCmd IC.InstrumentConfiguration with
    admin = registrar
    instrumentId
    holderRequirements = []
    issuerRequirements
    isin = None
    cusip = None
    description

testMintRejectsZeroAmount : Script ()
testMintRejectsZeroAmount = do
  registrar <- allocateParty "registrar"
  alice <- allocateParty "alice"
  _cfg <- mkConfig registrar "BTC" [] "test"
  submitMustFail alice $ createCmd Mint.MintRequest with
    requestor = alice
    admin = registrar
    instrumentId = "BTC"
    amount = 0.0
    reference = "zero"
  pure ()

testMintRejectsNegativeAmount : Script ()
testMintRejectsNegativeAmount = do
  registrar <- allocateParty "registrar"
  alice <- allocateParty "alice"
  submitMustFail alice $ createCmd Mint.MintRequest with
    requestor = alice
    admin = registrar
    instrumentId = "BTC"
    amount = -10.0
    reference = "neg"
  pure ()

testBurnRejectsZeroAmount : Script ()
testBurnRejectsZeroAmount = do
  registrar <- allocateParty "registrar"
  alice <- allocateParty "alice"
  holdingCid <- submit registrar $ createCmd H.Holding with
    admin = registrar
    owner = alice
    instrumentId = "BTC"
    amount = 5.0
    locked = False
  submitMustFail alice $ createCmd Burn.BurnRequest with
    requestor = alice
    admin = registrar
    instrumentId = "BTC"
    amount = 0.0
    reference = "zero-burn"
    lockedHoldingCid = holdingCid
  pure ()

testMintAcceptRejectsInstrumentIdMismatch : Script ()
testMintAcceptRejectsInstrumentIdMismatch = do
  registrar <- allocateParty "registrar"
  alice <- allocateParty "alice"
  cfgCid <- mkConfig registrar "ETH" [] "ether"
  reqCid <- submit alice $ createCmd Mint.MintRequest with
    requestor = alice
    admin = registrar
    instrumentId = "BTC"
    amount = 100.0
    reference = "mismatch"
  submitMustFail registrar $ exerciseCmd reqCid Mint.MintRequest_Accept with
    configCid = cfgCid
    issuerClaims = []
  pure ()

testMintAcceptRejectsMissingCredential : Script ()
testMintAcceptRejectsMissingCredential = do
  registrar <- allocateParty "registrar"
  alice <- allocateParty "alice"
  credIssuer <- allocateParty "kyc-issuer"
  cfgCid <- mkConfig registrar "BOND"
    [ Cred.CredentialRequirement with
        issuer = credIssuer
        property = "kyc"
        value = "tier1"
    ]
    "regulated bond"
  reqCid <- submit alice $ createCmd Mint.MintRequest with
    requestor = alice
    admin = registrar
    instrumentId = "BOND"
    amount = 100.0
    reference = "no-cred"
  submitMustFail registrar $ exerciseCmd reqCid Mint.MintRequest_Accept with
    configCid = cfgCid
    issuerClaims = []
  pure ()
