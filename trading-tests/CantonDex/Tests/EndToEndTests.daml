  (reqCid, baseCid, quoteCid, receiptCid) <-
    authorAddAllocations operator factoryCid poolCid dvpCid lpRegistrar 10.0 200000.0 now markerContext
  submitMustFail (actAs [operator, lpRegistrar]) $
    exerciseCmd dvpCid Dvp.PoolLiquidityRules_SettleAddLiquidity with
      expectedPoolId = poolId; poolCid; poolStateCid = stateCid; lpPolicyCid = policyCid
      requestCid = Some reqCid; acceptanceCid = None; recipient = lpRegistrar
      lpBaseDepositCid = baseCid; lpQuoteDepositCid = quoteCid; lpReceiptCid = receiptCid
      baseFactoryCid = factoryCid; quoteFactoryCid = factoryCid; lpFactoryCid = factoryCid
      baseQuoteSettleCid = settleCid; lpSettleCid = settleCid
      baseAmount = 10.0; quoteAmount = 200000.0; minLpTokens = 0.0; knownTotalLpSupply = 0.0
      requestedAt = now; poolAdminExtraArgs = markerContext; lpRegistrarExtraArgs = emptyExtraArgs
