-- | DEX-side adapter exposing our MockRegistry through the Splice
-- token-standard test interface (RegistryApiV2), so the matched-trade
-- workflow can be driven exactly the way upstream's TradingAppV2 tests
-- expect. Minimal: only the AllocationFactory + SettlementFactory methods
-- the flow exercises are filled in; the rest are loud `error` placeholders.
module CantonDex.TokenStandardHarness.DexRegistry where

import Daml.Script

import Splice.Api.Token.AllocationV2 qualified as V2
import Splice.Api.Token.AllocationInstructionV2 qualified as V2
import Splice.Api.Token.TransferInstructionV2 qualified as V2
import Splice.Api.Token.MetadataV1

import Splice.Testing.Utils
import Splice.Testing.TokenStandard.RegistryApiV2

import CantonDex.Testing.MockRegistry qualified as Mock

data DexRegistry = DexRegistry
  with
    admin : Party
    allocationFactory : ContractId V2.AllocationFactory
    settlementFactory : ContractId V2.SettlementFactory

-- | Boot a DexRegistry whose factories observe `users`.
initialize : Party -> [Party] -> Script DexRegistry
initialize admin users = do
  allocFactoryCid <- submit admin $
    createCmd Mock.MockAllocationFactory with admin; users; requireContext = False
  settleFactoryCid <- submit admin $
    createCmd Mock.MockSettlementFactory with admin; users; requireContext = False
  pure DexRegistry with
    admin
    allocationFactory = toInterfaceContractId allocFactoryCid
    settlementFactory = toInterfaceContractId settleFactoryCid

instance RegistryApi DexRegistry where
  getAllocationFactory registry arg = pure EnrichedFactoryChoice with
    factoryCid = registry.allocationFactory
    arg
    disclosures = mempty

  getSettlementFactory registry arg = pure EnrichedFactoryChoice with
    factoryCid = registry.settlementFactory
    arg
    disclosures = mempty

  -- Unused by the MatchedTrade flow; fail loud rather than stub silently.
  getTransferFactory _ _ = error "DexRegistry: TransferFactory not implemented"
  getAllocation_WithdrawContext _ _ _ = error "DexRegistry: Allocation_Withdraw context not implemented"
  getAllocation_CancelContext _ _ _ = error "DexRegistry: Allocation_Cancel context not implemented"
  getAllocationInstruction_WithdrawContext _ _ _ = error "DexRegistry: AllocationInstruction_Withdraw context not implemented"
  getAllocationInstruction_AcceptContext _ _ _ = error "DexRegistry: AllocationInstruction_Accept context not implemented"
  getTransferInstruction_AcceptContext _ _ _ = error "DexRegistry: TransferInstruction_Accept context not implemented"
  getTransferInstruction_RejectContext _ _ _ = error "DexRegistry: TransferInstruction_Reject context not implemented"
  getTransferInstruction_WithdrawContext _ _ _ = error "DexRegistry: TransferInstruction_Withdraw context not implemented"
