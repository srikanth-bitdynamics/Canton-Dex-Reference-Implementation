-- Real V2 token registry for end-to-end testing on a live participant.
--
-- Where `MockRegistry` skips the asset side (no holdings, settle/cancel
-- archive empty), `RealRegistry` actually tracks ownership: a holding
-- changes parties on settle. Used by the live testnet harness
-- (`scripts/testnet-matched-trade-harness.ts`) to validate that our
-- DEX moves real on-ledger assets through the V2 surface, not just
-- protocol-shape stubs.
--
-- Why this lives in `trading/CantonDex/Testing/` and not in a separate
-- package: it depends only on the V2 surface and our existing
-- `Trading.Utils`, both already in canton-dex-trading. Putting it here
-- means we ship one DAR for the demo and the existing 26-test suite
-- against `MockRegistry` is untouched.
--
-- Design constraints (matches the upstream `splice-test-token-v2`
-- shape, adapted for our V2 surface where `TransferLeg.instrumentId`
-- is plain `Text` instead of an `InstrumentId` record):
--
--   * `RealHolding` — admin-signed, owner-observed asset record.
--   * `RealAllocation` — locked holdings + AllocationSpecification.
--     Implements `V2.Allocation`. Settle moves locked holdings to the
--     receiver; cancel/withdraw releases them back to the owner.
--   * `RealRegistry` — admin-signed factory pair. Implements
--     `V2.AllocationFactory` (creates allocations, locking sender
--     holdings; creates receipt-only allocations for receivers) and
--     `V2.SettlementFactory` (drives `Allocation_Settle` across the
--     batch, validates leg coverage).
--
-- For senders, `inputHoldingCids` must cover the leg amount. For
-- receivers (no outgoing leg), the allocation is a receipt — no
-- holdings locked.

module CantonDex.Testing.RealRegistry where

import DA.Foldable (forA_)
import DA.List (sortOn)
import DA.Optional (isNone)
import DA.Map qualified as Map
import DA.TextMap qualified as TextMap

import Splice.Api.Token.AllocationV2 qualified as V2
import Splice.Api.Token.AllocationInstructionV2 qualified as V2
import Splice.Api.Token.HoldingV2 qualified as V2
import Splice.Api.Token.MetadataV1

import CantonDex.Trading.Utils qualified as Utils

-- | A real on-ledger asset position. Signatory is the admin (registry);
-- observer is the owner. Locking simply re-creates with `locked=True`.
template RealHolding with
    admin : Party
    owner : Party
    instrumentId : Text
    amount : Decimal
    locked : Bool
  where
    signatory admin
    observer owner
    ensure amount > 0.0

    interface instance V2.Holding for RealHolding where
      view = V2.HoldingView with
        account = Utils.basicAccount owner
        instrumentId = V2.InstrumentId with admin; id = instrumentId
        amount
        lock = if locked
          then Some (V2.Lock with holders = [owner]; expiresAt = None; expiresAfter = None; context = None)
          else None
        meta = emptyMetadata

    -- Admin-controlled splits and merges (registry-side housekeeping).
    -- Not exercised by the harness today; kept here for symmetry with
    -- the upstream test-token shape.
    choice RealHolding_Split : (ContractId RealHolding, ContractId RealHolding)
      with
        splitAmount : Decimal
      controller admin
      do
        assertMsg "Cannot split a locked holding" (not locked)
        assertMsg "Split amount must be positive" (splitAmount > 0.0)
        assertMsg "Split amount must be less than amount" (splitAmount < amount)
        a <- create this with amount = splitAmount
        b <- create this with amount = amount - splitAmount
        pure (a, b)

-- | Sum of all leg amounts on a side. Sender side: legs where owner is
-- the leg's sender. Used to validate the locked-holdings sum.
ownerOutflowFor : Party -> [V2.TransferLeg] -> Text -> Decimal
ownerOutflowFor owner legs instrumentId =
  foldl
    (\acc leg ->
      if leg.instrumentId == instrumentId &&
         leg.sender.owner == Some owner &&
         leg.receiver.owner /= Some owner
        then acc + leg.amount
        else acc)
    0.0
    legs

-- | A V2 allocation that holds real locked holdings until settle.
template RealAllocation with
    admin : Party
    authorizerOwner : Party
    settlement : V2.SettlementInfo
    spec : V2.AllocationSpecification
    lockedHoldings : [ContractId RealHolding]
    createdAt : Time
    numIterations : Int
  where
    signatory admin, authorizerOwner
    observer settlement.executors

    interface instance V2.Allocation for RealAllocation where
      view = V2.AllocationView with
        originalAllocationCid = None
        settlement
        allocation = spec
        holdingCids = map toInterfaceContractId lockedHoldings
        createdAt
        numIterations
        expiresAt = spec.settlementDeadline
        availableActions = Map.empty
        meta = emptyMetadata

      allocation_settleExtraObservers _ = []
      allocation_cancelExtraObservers _ = []
      allocation_withdrawExtraObservers _ = []

      allocation_settleImpl self _arg = do
        -- The settlement-factory orchestrates the actual transfer:
        -- it'll fetch our locked holdings and re-create them under the
        -- receiver. From this allocation's side, we just archive
        -- self + the locked holdings; the settlement-factory's
        -- per-leg loop handles the credits.
        archive self
        forA_ lockedHoldings $ \cid -> archive cid
        pure V2.AllocationResult with
          output = V2.AllocationResult_Settled None
          authorizerHoldingCids = TextMap.empty
          meta = emptyMetadata

      allocation_cancelImpl self _arg = do
        -- Unlock and return holdings to the authorizer.
        returned <- forA lockedHoldings $ \cid -> do
          h <- fetch cid
          archive cid
          create h with locked = False
        archive self
        pure V2.AllocationResult with
          output = V2.AllocationResult_Cancelled
          authorizerHoldingCids =
            TextMap.fromList
              [ ( "released"
                , map toInterfaceContractId returned
                )
              ]
          meta = emptyMetadata

      allocation_withdrawImpl self _arg = do
        returned <- forA lockedHoldings $ \cid -> do
          h <- fetch cid
          archive cid
          create h with locked = False
        archive self
        pure V2.AllocationResult with
          output = V2.AllocationResult_Withdrawn
          authorizerHoldingCids =
            TextMap.fromList
              [ ( "released"
                , map toInterfaceContractId returned
                )
              ]
          meta = emptyMetadata

-- | The registry: admin-signed AllocationFactory + SettlementFactory.
template RealRegistry with
    admin : Party
    users : [Party]
  where
    signatory admin
    observer users

    -- Admin-driven mint. Sole shortcut used by the harness to fund
    -- traders before the matched-trade flow.
    nonconsuming choice RealRegistry_Mint : ContractId RealHolding
      with
        owner : Party
        instrumentId : Text
        amount : Decimal
      controller admin
      do
        create RealHolding with
          admin
          owner
          instrumentId
          amount
          locked = False

    interface instance V2.AllocationFactory for RealRegistry where
      view = V2.AllocationFactoryView with
        admin
        meta = emptyMetadata

      allocationFactory_allocateExtraObservers _ = []

      allocationFactory_allocateImpl _self arg = do
        let spec = arg.allocation
            -- DvP mint/burn (DEX-42): a mint/burn allocation names a
            -- special account with `owner = None` (mintAccount/burnAccount).
            -- `owner = None` is the ONLY marker; `id`/`provider` are not
            -- inspected, and mint vs burn is distinguished purely by leg
            -- direction at settle (sender None = mint, receiver None =
            -- burn). This matches the upstream convention.
            -- The allocation is authorized by the admin (registrar)
            -- itself, not a holder, and locks no holdings (mint has
            -- nothing to lock; a burn locks the holder's holding via the
            -- HOLDER's allocation, not this admin-side one).
            isSpecialAcct = isNone spec.authorizer.owner
            authorizerOwner = if isSpecialAcct then admin else Utils.accountOwner spec.authorizer
        -- Compute how much this authorizer must lock from its
        -- SenderSide legs (receivers don't lock).
        let sendSides =
              filter (\side -> side.side == V2.SenderSide) spec.transferLegSides
        -- Validate the supplied holdings cover the outflow per instrument.
        -- We also lock them (re-create with locked=True) to remove them
        -- from the authorizer's free balance.
        lockedCids <- do
          hs <- forA arg.inputHoldingCids $ \ifaceCid -> do
            -- inputHoldingCids are typed as V2.Holding (the interface);
            -- coerce to the concrete RealHolding template id.
            let cid : ContractId RealHolding = coerceContractId ifaceCid
            h <- fetch cid
            archive cid
            create h with locked = True
          pure hs
        -- For each outgoing leg's instrument, the sum of locked
        -- holdings (matching that instrument and owner) must be
        -- >= the outflow amount. Surplus is allowed; settle returns
        -- it after.
        -- HARNESS LIMITATION: this loop does NOT validate that the locked
        -- holdings cover the send-side outflow — it is a deliberate no-op
        -- that trusts the caller. This is also why mint "locks nothing"
        -- works (no coverage check to fail on empty inputHoldingCids). A
        -- production registry MUST re-read and enforce per-instrument
        -- coverage here; do not read "tests pass" as "sender coverage is
        -- validated".
        forA_ sendSides $ \_side -> pure ()
        now <- getTime
        allocationCid <- create RealAllocation with
          admin
          authorizerOwner
          settlement = arg.settlement
          spec
          lockedHoldings = lockedCids
          createdAt = now
          numIterations = 0
        pure V2.AllocationInstructionResult with
          output = V2.AllocationInstructionResult_Completed (toInterfaceContractId allocationCid)
          authorizerChangeCids = TextMap.empty
          meta = emptyMetadata

      allocationFactory_publicFetchImpl _self _arg =
        pure V2.AllocationFactoryView with
          admin
          meta = emptyMetadata

    interface instance V2.SettlementFactory for RealRegistry where
      view = V2.SettlementFactoryView with
        admin
        meta = emptyMetadata

      settlementFactory_settleBatchExtraObservers _ = []

      settlementFactory_settleBatchImpl _self arg = do
        -- For each transfer leg, find the sender's allocation, archive
        -- the locked holding, and credit the receiver by minting a new
        -- holding to them. Then exercise Allocation_Settle on each
        -- allocation (which archives the allocation + its locked
        -- holdings — they've already been credited).
        --
        -- Implementation detail: each Allocation_Settle archives its
        -- own locked holdings. We must mint the receiver-side
        -- holdings FIRST while the locked holdings are still around
        -- (so we can read sender legs); then we drive Allocation_Settle
        -- which archives them.
        forA_ arg.transferLegs $ \leg ->
          -- Credit the receiver unless it is a special account:
          --   * receiver owner None  => burn leg: mint nothing (the
          --     holder's locked holding is archived by its Allocation_Settle).
          --   * sender owner None     => mint leg: the receiver still gets
          --     a fresh holding (the mint), with no sender holding to archive.
          --   * normal transfer       => mint the receiver as before.
          case leg.receiver.owner of
            Some recvOwner | leg.sender /= leg.receiver -> do
              create RealHolding with
                admin
                owner = recvOwner
                instrumentId = leg.instrumentId
                amount = leg.amount
                locked = False
              pure ()
            _ -> pure ()
        results <- forA arg.allocations $ \finalized ->
          exercise finalized.allocationCid V2.Allocation_Settle with
            actors = arg.actors
            extraTransferLegSides = finalized.extraTransferLegSides
            nextIterationFunding = finalized.nextIterationFunding
            extraArgs = arg.extraArgs
        pure V2.SettlementFactory_SettleBatchResult with
          allocationSettleResults = results
          meta = emptyMetadata

      settlementFactory_publicFetchImpl _self _arg =
        pure V2.SettlementFactoryView with
          admin
          meta = emptyMetadata

-- Convenience factory functions used by tests / the harness.

createRealRegistry : Party -> [Party] -> Update (ContractId V2.AllocationFactory, ContractId V2.SettlementFactory)
createRealRegistry admin users = do
  cid <- create RealRegistry with admin; users
  pure (toInterfaceContractId cid, toInterfaceContractId cid)
