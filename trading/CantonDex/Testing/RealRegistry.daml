-- Real V2 token registry for end-to-end testing on a live participant.
-- Unlike MockRegistry it tracks ownership: a holding changes parties on
-- settle. Used by the testnet harness to prove the DEX moves real
-- on-ledger assets through the V2 surface. Lives under Testing/ because it
-- depends only on the V2 surface + Trading.Utils, so the demo ships one DAR.
--
-- Testing-only. Production code MUST NOT import this module.

module CantonDex.Testing.RealRegistry where

import DA.Foldable (forA_)
import DA.List (sortOn)
import DA.Optional (isNone)
import DA.Map qualified as Map
import DA.TextMap qualified as TextMap

import Splice.Api.Token.AllocationV2 qualified as V2
import Splice.Api.Token.AllocationInstructionV2 qualified as V2
import Splice.Api.Token.HoldingV2 qualified as V2
import Splice.Api.Token.MetadataV1

import CantonDex.Trading.Utils qualified as Utils

-- | A real on-ledger asset position; locking re-creates with locked=True.
template RealHolding with
    admin : Party
    owner : Party
    instrumentId : Text
    amount : Decimal
    locked : Bool
  where
    signatory admin
    observer owner
    ensure amount > 0.0

    interface instance V2.Holding for RealHolding where
      view = V2.HoldingView with
        account = Utils.basicAccount owner
        instrumentId = V2.InstrumentId with admin; id = instrumentId
        amount
        lock = if locked
          then Some (V2.Lock with holders = [owner]; expiresAt = None; expiresAfter = None; context = None)
          else None
        meta = emptyMetadata

    choice RealHolding_Split : (ContractId RealHolding, ContractId RealHolding)
      with
        splitAmount : Decimal
      controller admin
      do
        assertMsg "Cannot split a locked holding" (not locked)
        assertMsg "Split amount must be positive" (splitAmount > 0.0)
        assertMsg "Split amount must be less than amount" (splitAmount < amount)
        a <- create this with amount = splitAmount
        b <- create this with amount = amount - splitAmount
        pure (a, b)

-- | Sender-side outflow for an owner on one instrument (locked-sum check).
ownerOutflowFor : Party -> [V2.TransferLeg] -> Text -> Decimal
ownerOutflowFor owner legs instrumentId =
  foldl
    (\acc leg ->
      if leg.instrumentId == instrumentId &&
         leg.sender.owner == Some owner &&
         leg.receiver.owner /= Some owner
        then acc + leg.amount
        else acc)
    0.0
    legs

template RealAllocation with
    admin : Party
    authorizerOwner : Party
    settlement : V2.SettlementInfo
    spec : V2.AllocationSpecification
    lockedHoldings : [ContractId RealHolding]
    createdAt : Time
    numIterations : Int
  where
    signatory admin, authorizerOwner
    observer settlement.executors

    interface instance V2.Allocation for RealAllocation where
      view = V2.AllocationView with
        originalAllocationCid = None
        settlement
        allocation = spec
        holdingCids = map toInterfaceContractId lockedHoldings
        createdAt
        numIterations
        expiresAt = spec.settlementDeadline
        availableActions = Map.empty
        meta = emptyMetadata

      allocation_settleExtraObservers _ = []
      allocation_cancelExtraObservers _ = []
      allocation_withdrawExtraObservers _ = []

      -- The settlement factory does the credits; this side just archives
      -- self + its locked holdings.
      allocation_settleImpl self _arg = do
        archive self
        forA_ lockedHoldings $ \cid -> archive cid
        pure V2.AllocationResult with
          output = V2.AllocationResult_Settled None
          authorizerHoldingCids = TextMap.empty
          meta = emptyMetadata

      -- Cancel / withdraw return the locked holdings to the authorizer.
      allocation_cancelImpl self _arg = do
        returned <- forA lockedHoldings $ \cid -> do
          h <- fetch cid
          archive cid
          create h with locked = False
        archive self
        pure V2.AllocationResult with
          output = V2.AllocationResult_Cancelled
          authorizerHoldingCids =
            TextMap.fromList
              [ ( "released"
                , map toInterfaceContractId returned
                )
              ]
          meta = emptyMetadata

      allocation_withdrawImpl self _arg = do
        returned <- forA lockedHoldings $ \cid -> do
          h <- fetch cid
          archive cid
          create h with locked = False
        archive self
        pure V2.AllocationResult with
          output = V2.AllocationResult_Withdrawn
          authorizerHoldingCids =
            TextMap.fromList
              [ ( "released"
                , map toInterfaceContractId returned
                )
              ]
          meta = emptyMetadata

template RealRegistry with
    admin : Party
    users : [Party]
  where
    signatory admin
    observer users

    -- Admin-driven mint; the harness uses it to fund traders.
    nonconsuming choice RealRegistry_Mint : ContractId RealHolding
      with
        owner : Party
        instrumentId : Text
        amount : Decimal
      controller admin
      do
        create RealHolding with
          admin
          owner
          instrumentId
          amount
          locked = False

    interface instance V2.AllocationFactory for RealRegistry where
      view = V2.AllocationFactoryView with
        admin
        meta = emptyMetadata

      allocationFactory_allocateExtraObservers _ = []

      allocationFactory_allocateImpl _self arg = do
        let spec = arg.allocation
            -- Mint/burn allocation: authorizer owner None (mint/burn account),
            -- authorized by the admin and locking nothing. Mint vs burn is by
            -- leg direction at settle (sender None = mint, receiver None = burn).
            isSpecialAcct = isNone spec.authorizer.owner
            authorizerOwner = if isSpecialAcct then admin else Utils.accountOwner spec.authorizer
        let sendSides =
              filter (\side -> side.side == V2.SenderSide) spec.transferLegSides
        lockedCids <- do
          hs <- forA arg.inputHoldingCids $ \ifaceCid -> do
            let cid : ContractId RealHolding = coerceContractId ifaceCid
            h <- fetch cid
            archive cid
            create h with locked = True
          pure hs
        -- HARNESS LIMITATION: send-side coverage is NOT validated here — a
        -- deliberate no-op that trusts the caller (also why mint "locks
        -- nothing" works). A production registry MUST enforce per-instrument
        -- coverage; "tests pass" does not mean coverage is validated.
        forA_ sendSides $ \_side -> pure ()
        now <- getTime
        allocationCid <- create RealAllocation with
          admin
          authorizerOwner
          settlement = arg.settlement
          spec
          lockedHoldings = lockedCids
          createdAt = now
          numIterations = 0
        pure V2.AllocationInstructionResult with
          output = V2.AllocationInstructionResult_Completed (toInterfaceContractId allocationCid)
          authorizerChangeCids = TextMap.empty
          meta = emptyMetadata

      allocationFactory_publicFetchImpl _self _arg =
        pure V2.AllocationFactoryView with
          admin
          meta = emptyMetadata

    interface instance V2.SettlementFactory for RealRegistry where
      view = V2.SettlementFactoryView with
        admin
        meta = emptyMetadata

      settlementFactory_settleBatchExtraObservers _ = []

      settlementFactory_settleBatchImpl _self arg = do
        -- Credit receivers FIRST (while locked holdings still exist), then
        -- drive Allocation_Settle, which archives each allocation + its
        -- locked holdings. Skip special accounts: receiver None = burn
        -- (mint nothing); sender None = mint (receiver still credited).
        forA_ arg.transferLegs $ \leg ->
          case leg.receiver.owner of
            Some recvOwner | leg.sender /= leg.receiver -> do
              create RealHolding with
                admin
                owner = recvOwner
                instrumentId = leg.instrumentId
                amount = leg.amount
                locked = False
              pure ()
            _ -> pure ()
        results <- forA arg.allocations $ \finalized ->
          exercise finalized.allocationCid V2.Allocation_Settle with
            actors = arg.actors
            extraTransferLegSides = finalized.extraTransferLegSides
            nextIterationFunding = finalized.nextIterationFunding
            extraArgs = arg.extraArgs
        pure V2.SettlementFactory_SettleBatchResult with
          allocationSettleResults = results
          meta = emptyMetadata

      settlementFactory_publicFetchImpl _self _arg =
        pure V2.SettlementFactoryView with
          admin
          meta = emptyMetadata

createRealRegistry : Party -> [Party] -> Update (ContractId V2.AllocationFactory, ContractId V2.SettlementFactory)
createRealRegistry admin users = do
  cid <- create RealRegistry with admin; users
  pure (toInterfaceContractId cid, toInterfaceContractId cid)
