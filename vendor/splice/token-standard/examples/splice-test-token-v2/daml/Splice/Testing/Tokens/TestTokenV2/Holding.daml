-- | Template to represent holdings of TestTokenV2 tokens.
module Splice.Testing.Tokens.TestTokenV2.Holding
( Token(..)
, fetchAndArchiveUnlockedToken
, fetchAndArchiveLockedToken
) where

import DA.Assert
import DA.Foldable (forA_)
import DA.Optional

import Splice.Api.Token.HoldingV1 qualified as V1
import Splice.Api.Token.HoldingV2 qualified as V2
import Splice.TokenStandard.Utils


template Token with
     holding : V2.HoldingView
  where
    -- We model a token that is jointly maintained by the account parties and the instrument admin
    -- to test that the authorization rules work our for that as well.
    signatory accountParties holding.instrumentId.admin holding.account, holding.instrumentId.admin

    ensure
      holding.amount > 0.0 -- positive amounts
      && isSome holding.account.owner -- holdings for regular accounts only

    interface instance V1.Holding for Token where
      view = downcast holding

    interface instance V2.Holding for Token where
      view = holding


fetchAndArchiveLockedToken : V2.InstrumentId -> V2.Account -> ContractId Token -> Update Token
fetchAndArchiveLockedToken expectedInstrumentId expectedOwner tokenCid = do
  token <- fetch tokenCid
  require' ("inputHolding.instrumentId", token.holding.instrumentId) isEqualR ("expectedInstrumentId", expectedInstrumentId)
  require' ("inputHolding.account", token.holding.account) isEqualR ("expectedOwner", expectedOwner)
  require "Token is locked" (isSome token.holding.lock)
  archive tokenCid
  return token

fetchAndArchiveUnlockedToken : V2.InstrumentId -> V2.Account -> ContractId Token -> Update Token
fetchAndArchiveUnlockedToken expectedInstrumentId expectedOwner tokenCid = do
  token <- fetch tokenCid
  require' ("inputHolding.instrumentId", token.holding.instrumentId) isEqualR ("expectedInstrumentId", expectedInstrumentId)
  require' ("inputHolding.account", token.holding.account) isEqualR ("expectedOwner", expectedOwner)
  forA_ token.holding.lock $ \lock ->
    case lock.expiresAt of
      None -> abort "input holding is locked indefinitely, cannot be used for transfer"
      Some expiresAt -> assertDeadlineExceeded "input holding lock expiresAt" expiresAt
  archive tokenCid
  return token
