-- | Templates for transferring TestTokenV2 tokens.
module Splice.Testing.Tokens.TestTokenV2.Transfer
( TokenTransferOffer(..)
, transferInstructionTransition
, applyTransferInstructionTransitions
) where

import DA.List (dedupSort)
import DA.Map qualified as Map
import DA.Optional

import Splice.Api.Token.MetadataV1
import Splice.Api.Token.HoldingV2 qualified as V2
import Splice.Api.Token.TransferInstructionV2 qualified as V2
import Splice.Api.Token.TransferEventsV2 as TransferEventsV2
import Splice.Testing.Tokens.TestTokenV2.AccountConfig
import Splice.Testing.Tokens.TestTokenV2.Holding
import Splice.Testing.Tokens.TestTokenV2.Util
import Splice.TokenStandard.Utils


-- | Transfer instruction representing a token transfer offer.
--
-- Its input holdings reference the locked tokens.
template TokenTransferOffer with
    actionAuthorizers : Map.Map V2.TransferInstructionAction [Party]
      -- ^ A map from actions to which parties have already authorized that action.
      -- As soon as an action is fully authorized, it is executed.
      -- Specifically:
      -- TIA_Accept must be approved by both account parties of both accounts.
      -- TIA_Reject must be approved by both account parties of receiver account.
      -- TIA_Withdraw must be approved by those account parties of the sender, which have
      -- already approved Accept.
    availableActions : Map.Map V2.TransferInstructionAction [[Party]]
      -- ^ Stored results of mkAvailableTransferActions at time of creation as we cannot
      -- access account contracts in view function.
    transfer : V2.Transfer
    originalInstructionCid : Optional (ContractId V2.TransferInstruction)
    mintAmount : Decimal
  where
    ensure isValidTransferV2 transfer
    signatory fromOptional [] (Map.lookup V2.TIA_Accept actionAuthorizers), transfer.instrumentId.admin
    -- Visible to anyone that has or can authorize an action
    observer dedupSort (concatMap concat (Map.values availableActions) <> concat (Map.values actionAuthorizers))

    interface instance V2.TransferInstruction for TokenTransferOffer where
      view = V2.TransferInstructionView with
        originalInstructionCid = originalInstructionCid
        transfer
        availableActions
        expiresAt =
          -- Note: in prod you would probably want to limit the maximal TTL to avoid a storage leak
          Some transfer.executeBefore
        meta = emptyMetadata

      transferInstruction_acceptExtraObservers = transferInstruction_acceptDefaultExtraObservers this
      transferInstruction_rejectExtraObservers = transferInstruction_rejectDefaultExtraObservers this
      transferInstruction_withdrawExtraObservers = transferInstruction_withdrawDefaultExtraObservers this

      transferInstruction_withdrawImpl self arg = do
        applyTransferInstructionTransitions this (Some self) arg.actors V2.TIA_Withdraw arg.extraArgs

      transferInstruction_rejectImpl self arg = do
        applyTransferInstructionTransitions this (Some self) arg.actors V2.TIA_Reject arg.extraArgs

      transferInstruction_acceptImpl self arg = do
        applyTransferInstructionTransitions this (Some self) arg.actors V2.TIA_Accept arg.extraArgs

    -- Implemented here so that we do not have to pull in the Rules contract.
    interface instance TransferEventsV2.EventLog for TokenTransferOffer where
      view = TransferEventsV2.EventLogView with
        admin = transfer.instrumentId.admin
        meta = emptyMetadata

      eventLog_holdingsChangeImpl = eventLog_holdingsChangeDefaultImpl transfer.instrumentId.admin

-- The state transitions for a transfer offer
transferInstructionTransition
  : TokenTransferOffer
  -> Optional (ContractId V2.TransferInstruction)
  -> [Party]
  -> AccountConfigMap
  -> ExtraArgs
  -> TransferInstructionState
  -> TransferInstructionState
  -> Update V2.TransferInstructionResult
transferInstructionTransition this _oSelf _actors _accountMap _extraArgs TIS_Init TIS_Withdrawn = do
  pure V2.TransferInstructionResult with
    output = V2.TransferInstructionResult_Failed
    senderChangeCids = this.transfer.inputHoldingCids
    meta = emptyMetadata

transferInstructionTransition this _oSelf _actors _accountMap extraArgs TIS_Authorized TIS_Withdrawn = do
  senderChangeCids <- unlockTokenTransferOffer "transfer withdrawn" this extraArgs
  pure V2.TransferInstructionResult with
    output = V2.TransferInstructionResult_Failed
    senderChangeCids
    meta = emptyMetadata

transferInstructionTransition this _oSelf _actors _accountMap extraArgs TIS_Authorized TIS_Rejected = do
  senderChangeCids <- unlockTokenTransferOffer "transfer rejected" this extraArgs
  pure V2.TransferInstructionResult with
    output = V2.TransferInstructionResult_Failed
    senderChangeCids
    meta = emptyMetadata

transferInstructionTransition this oSelf actors accountMap extraArgs TIS_Init TIS_Authorized = do
    let admin = this.transfer.instrumentId.admin
    senderChangeCids <- debitHoldings this
    inputHoldingCids <- createLockedInputs this.transfer
    -- log the tx history v2 event
    eventLogCid <- getEventLogFromContext extraArgs.context
    logHoldingsChange eventLogCid TransferEventsV2.EventLog_HoldingsChange with
      admin
      account = this.transfer.sender
      inputHoldingCids = this.transfer.inputHoldingCids
      transferLegSides = []
      outputHoldingCids = inputHoldingCids <> senderChangeCids
      observers = accountParties admin this.transfer.sender
      extraArgs = ExtraArgs with
        context = emptyChoiceContext
        meta = reasonToMeta ("lock for transfer to " <> show this.transfer.receiver) emptyMetadata

    let
      newActionAuthorizers =
        insertWithUnion V2.TIA_Accept actors this.actionAuthorizers
      spec = transferInstructionStateMachineSpec this.transfer.sender this.transfer.receiver
      state = getState admin spec newActionAuthorizers

    case state of
      TIS_Authorized -> do
        let newAvailableActions = mkAvailableActions admin spec newActionAuthorizers accountMap
        pendingInstrCid <- create this with
          actionAuthorizers = newActionAuthorizers
          availableActions = newAvailableActions
          transfer.inputHoldingCids = inputHoldingCids
          originalInstructionCid = oSelf
        pure V2.TransferInstructionResult with
          senderChangeCids
          output = V2.TransferInstructionResult_Pending (toInterfaceContractId pendingInstrCid)
          meta = emptyMetadata
      TIS_Accepted -> do
        let
          instr = this with
            transfer = this.transfer with inputHoldingCids
        res <- transferInstructionTransition instr oSelf actors accountMap extraArgs TIS_Authorized TIS_Accepted
        return res with senderChangeCids = senderChangeCids ++ res.senderChangeCids
      _ -> abort $ "Unexpected state after authorizing transfer instruction: " <> show state

transferInstructionTransition this _oSelf _actors _accountMap extraArgs TIS_Authorized TIS_Accepted = do
  senderChangeCids <- debitHoldings this
  tokenCid <- create Token with
    holding = (senderHoldingFromTransfer this.transfer) with
      account = this.transfer.receiver
  -- log v2 history event
  tokenRulesCid <- getEventLogFromContext extraArgs.context
  logTransfer (toInterfaceContractId tokenRulesCid)
    this.transfer
    senderChangeCids
    [toInterfaceContractId tokenCid]
  pure V2.TransferInstructionResult with
    senderChangeCids
    output = V2.TransferInstructionResult_Completed with
      receiverHoldingCids = [toInterfaceContractId tokenCid]
    meta = case this.transfer.sender.owner of
      None -> emptyMetadata
      Some owner -> mkMetaTransferFrom owner (reasonFromMeta this.transfer.meta)

transferInstructionTransition this oSelf actors accountMap extraArgs TIS_Init TIS_Accepted = do
  transferInstructionTransition this oSelf actors accountMap extraArgs TIS_Init TIS_Authorized

transferInstructionTransition _this _oSelf _actors _accountMap _extraArgs fromState toState =
  abort $ "Unsupported state transition: " <> show (fromState, toState)

applyTransferInstructionTransitions
  : TokenTransferOffer
  -> Optional (ContractId V2.TransferInstruction)
  -> [Party]
  -> V2.TransferInstructionAction
  -> ExtraArgs
  -> Update V2.TransferInstructionResult
applyTransferInstructionTransitions this@TokenTransferOffer{..} oSelf actors action extraArgs = do
  let admin = transfer.instrumentId.admin
  accountMap <- extractAccountConfigMap
      admin
      extraArgs
      [transfer.sender, transfer.receiver]

  let
    mkStateMachine v = transferInstructionStateMachineSpec v.transfer.sender v.transfer.receiver

    mkPending newActionAuthorizers newAvailableActions = do
      pendingInstrCid <- create this with
        originalInstructionCid = fmap coerceContractId oSelf
        actionAuthorizers = newActionAuthorizers
        availableActions = newAvailableActions
      return V2.TransferInstructionResult with
            output = V2.TransferInstructionResult_Pending with
              transferInstructionCid = toInterfaceContractId pendingInstrCid
            senderChangeCids = []
            meta = emptyMetadata

    tryUseAuthority actors action result authState accountMap extraArgs = case result.output of
      V2.TransferInstructionResult_Pending instrCid ->
        tryUseAccountAuthorityForTIA' actors action instrCid authState accountMap extraArgs
      _ -> return None

    transition = transferInstructionTransition this oSelf actors accountMap extraArgs

  applyStateMachineTransitions
    admin this oSelf actors action mkStateMachine accountMap
    transition mkPending tryUseAuthority extraArgs


-- | Sum up and archive input holdings
sumAndArchiveHoldings : V2.Transfer -> Update Decimal
sumAndArchiveHoldings transfer = do
  -- consume all inputs
  inputAmounts <- forA transfer.inputHoldingCids (\cid -> do
    let tokenCid = coerceContractId cid : ContractId Token
    token <- fetch tokenCid
    archive tokenCid
    require' ("inputHolding.account", token.holding.account) isEqualR ("transfer.sender", transfer.sender)
    require' ("inputHolding.instrumentId", token.holding.instrumentId) isEqualR ("transfer.instrumentId", transfer.instrumentId)
    pure token.holding.amount
    )
  return (sum inputAmounts)

-- | Debit an amount from holdings
debitHoldings : TokenTransferOffer -> Update [ContractId V2.Holding]
debitHoldings offer = do
  -- consume all inputs
  inputAmount <- sumAndArchiveHoldings offer.transfer
  require' ("inputAmount + mintAmount for " <> show offer.transfer.instrumentId, inputAmount + offer.mintAmount) isGreaterOrEqualR
    ("transfer.amount", offer.transfer.amount)

  -- split off change
  let remainder = inputAmount - offer.transfer.amount
  if remainder <= 0.0 then pure [] else do
    cid <- create Token with
      holding = (senderHoldingFromTransfer offer.transfer) with
        amount = remainder
    pure [toInterfaceContractId cid]

-- | Create a locked input for a transfer
createLockedInputs : V2.Transfer -> Update [ContractId V2.Holding]
createLockedInputs transfer = do
  -- lock the amount to be transferred
  let admin = transfer.instrumentId.admin
  lockedCid <- create Token with
    holding = (senderHoldingFromTransfer transfer) with
      lock = Some $ V2.Lock with
        holders = admin :: accountParties admin transfer.sender
        expiresAt = Some transfer.executeBefore
        expiresAfter = None
        context = Some $ "transfer to " <> show transfer.receiver
  pure [coerceContractId lockedCid]


-- Utilities
------------

unlockTokenTransferOffer : Text -> TokenTransferOffer -> ExtraArgs -> Update [ContractId V2.Holding]
unlockTokenTransferOffer reason offer extraArgs = do
    let transfer = offer.transfer
    sumAndArchiveHoldings transfer
    tokenCid <- toInterfaceContractId <$> create Token with
      holding = senderHoldingFromTransfer transfer
    -- log v2 history event
    eventLogCid <- getEventLogFromContext extraArgs.context
    let admin = transfer.instrumentId.admin
    logHoldingsChange eventLogCid TransferEventsV2.EventLog_HoldingsChange with
      admin
      account = transfer.sender
      inputHoldingCids = transfer.inputHoldingCids
      transferLegSides = []
      outputHoldingCids = [toInterfaceContractId tokenCid]
      observers = accountParties admin transfer.sender
      extraArgs = ExtraArgs with
        context = emptyChoiceContext
        meta = reasonToMeta reason emptyMetadata
    return [tokenCid]

senderHoldingFromTransfer : V2.Transfer -> V2.HoldingView
senderHoldingFromTransfer transfer = V2.HoldingView with
  account = transfer.sender
  amount = transfer.amount
  instrumentId = transfer.instrumentId
  lock = None
  meta = emptyMetadata
