-- | Utility functions for the TestTokenV2 module.
module Splice.Testing.Tokens.TestTokenV2.Util
( union
, insertWithUnion
, tokenRulesContextKey
, getTokenRulesFromContext
, getEventLogFromContext

  -- * V1/V2 compatibility
, CallSource(..)
, archiveIfCalledFromV2
) where

import DA.List (dedupSort)
import DA.Map qualified as Map
import DA.TextMap qualified as TextMap

import Splice.Api.Token.MetadataV1
import Splice.Api.Token.TransferEventsV2 qualified as TransferEventsV2


-- Set theoretic union for sets represented as sorted deduplicated lists.
union : (Ord a) => [a] -> [a] -> [a]
union x y = dedupSort (x ++ y)

-- Insert into a map with values that are sets represented as sorted deduplicated lists.
insertWithUnion : (Ord k, Ord v) => k -> [v] -> Map.Map k [v] -> Map.Map k [v]
insertWithUnion = Map.insertWith union

-- Event log retrieval
----------------------

tokenRulesContextKey : Text
tokenRulesContextKey = "testTokenV2/tokenRules"

getTokenRulesFromContext : ChoiceContext -> Update AnyContractId
getTokenRulesFromContext context = do
  case TextMap.lookup tokenRulesContextKey context.values of
    Some (AV_ContractId cid) -> pure cid
    None -> fail $ "Context value for '" <> tokenRulesContextKey <> "' not found"
    v -> fail $ "Failed to decode context value for '" <> tokenRulesContextKey <> "': " <> show v

getEventLogFromContext : ChoiceContext -> Update (ContractId TransferEventsV2.EventLog)
getEventLogFromContext context = coerceInterfaceContractId <$> getTokenRulesFromContext context


-- V1/V2 compatibility
----------------------

data CallSource = CalledFromV1 | CalledFromV2

archiveIfCalledFromV2 : HasArchive t => CallSource -> Optional (ContractId t) -> Update ()
archiveIfCalledFromV2 CalledFromV2 (Some cid) = archive cid
archiveIfCalledFromV2 CalledFromV2 None = pure ()
archiveIfCalledFromV2 CalledFromV1 _ = pure ()

