-- | V2 registry for the TestTokenV2.
module Splice.Testing.Registries.TestTokenV2_RegistryV2
  (
    -- * Setup
    TestTokenV2RegistryConfig(..)
  , defaultTestTokenV2RegistryConfig

  , TestTokenV2Registry(..)
  , initialize

  , mint
  , makeAccountIfMissing
  ) where


import DA.Action (void)
import DA.Foldable (forA_, Foldable(foldMap))
import DA.List (dedup)
import DA.Optional (catOptionals, fromSomeNote)
import DA.Text qualified as T
import DA.TextMap qualified as TextMap

import Daml.Script

import Splice.Api.Token.MetadataV1
import Splice.Api.Token.AllocationV1 qualified as V1
import Splice.Api.Token.TransferInstructionV1 qualified as V1
import Splice.Api.Token.AllocationInstructionV1 qualified as V1
import Splice.Api.Token.HoldingV2 qualified as V2
import Splice.Api.Token.AllocationV2 qualified as V2
import Splice.Api.Token.TransferInstructionV2 qualified as V2
import Splice.Api.Token.AllocationInstructionV2 qualified as V2

import Splice.TokenStandard.Utils

import Splice.Testing.Tokens.TestTokenV2 as TestTokenV2
import Splice.Testing.Tokens.TestTokenV2.Holding (Token(..))
import Splice.Testing.Tokens.TestTokenV2.Util (tokenRulesContextKey)
import Splice.Testing.Tokens.TestTokenV2.AccountConfig as AccountConfig
import Splice.Testing.TokenStandard.RegistryApi qualified as RegistryApiV1
import Splice.Testing.TokenStandard.RegistryApiV2 qualified as RegistryApiV2
import Splice.Testing.TokenStandard.WalletClientV2 qualified as WalletClientV2
import Splice.Testing.Utils


-- Registry representation
--------------------------

-- | A reference to a mock amulet registry.
data TestTokenV2Registry = TestTokenV2Registry with
    admin : Party
  deriving (Eq, Ord, Show)

-- | Note that all choice contexts will refer uniformly to the token rules, so that
-- reuse of one choice context across multiple token standard choices is possible.
instance RegistryApiV2.RegistryApi TestTokenV2Registry where
  getTransferFactory = registryApi_getTransferFactoryV2
  getAllocationFactory = registryApi_getAllocationFactoryV2
  getSettlementFactory = registryApi_getSettlementFactoryV2
  getAllocation_WithdrawContext = registryApi_getWithdrawContextV2
  getAllocation_CancelContext = registryApi_getCancelContextV2
  getAllocationInstruction_WithdrawContext = registryApi_getAllocationInstructionContextV2
  getAllocationInstruction_AcceptContext = registryApi_getAllocationInstructionContextV2
  getTransferInstruction_AcceptContext = registryApi_getTransferOfferContextV2
  getTransferInstruction_RejectContext = registryApi_getTransferOfferContextV2
  getTransferInstruction_WithdrawContext = registryApi_getTransferOfferContextV2

instance RegistryApiV1.RegistryApi TestTokenV2Registry where
  getTransferFactory = registryApi_getTransferFactoryV1
  getAllocationFactory = registryApi_getAllocationFactoryV1
  getAllocation_WithdrawContext = registryApi_getWithdrawContextV1
  getAllocation_CancelContext = registryApi_getCancelContextV1
  getAllocation_TransferContext = registryApi_getAllocationTransferContextV1
  getTransferInstruction_AcceptContext = registryApi_getTransferOfferContextV1
  getTransferInstruction_RejectContext = registryApi_getTransferOfferContextV1
  getTransferInstruction_WithdrawContext = registryApi_getTransferOfferContextV1

-- Registry initialization
--------------------------

data TestTokenV2RegistryConfig = TestTokenV2RegistryConfig
  with
    adminPartyName : Text
  deriving (Eq, Show)

defaultTestTokenV2RegistryConfig : TestTokenV2RegistryConfig
defaultTestTokenV2RegistryConfig = TestTokenV2RegistryConfig with
  adminPartyName = "adminTT2"

-- | Initialize the test token v2 registry.
initialize : TestTokenV2RegistryConfig -> Script TestTokenV2Registry
initialize config = do
  admin <- allocateParty config.adminPartyName
  submit admin $ createCmd TestTokenV2.TokenRules with admin
  pure TestTokenV2Registry with admin

-- | Mint test token instrument
mint : TestTokenV2Registry -> V2.Account -> Text -> Decimal -> Script ()
mint registry account intrumentName amount = do
  -- offer mint
  [(tokenRulesCid, _)] <- query @TestTokenV2.TokenRules registry.admin
  now <- getTime
  let admin = registry.admin
  receiverConfig <- case account.provider of
      None -> pure $ AccountConfig with
        admin
        account
        ownerConfig = PartyConfig True True
        providerConfig = PartyConfig False False
      Some _ -> do
        optAccountConfig <- getAccountConfig' registry account
        case optAccountConfig of
          None -> abort $ "Cannot mint, as account config not found for account" <> show account
          Some (_cid, config, _disclosures) -> pure config
  result <- submit registry.admin $ exerciseCmd tokenRulesCid TestTokenV2.TokenRules_OfferMint with
    receiver = account
    instrumentId = V2.InstrumentId with
      id = intrumentName
      admin = registry.admin
    amount = amount
    offeredAt = now
    receiverConfig
  -- have receiver accept immediately
  let offerCid = toInterfaceContractId result.offerCid
  let accept = V2.TransferInstruction_Accept with
        actors = accountParties admin account
        extraArgs = ExtraArgs with
          context = emptyChoiceContext
          meta = emptyMetadata
  context <- registryApi_getTransferOfferContextV2 registry offerCid emptyMetadata
  void $ WalletClientV2.extractAndCheckTxHistory [registry.admin] $
    submitResultAndTree (foldMap actAs (accountParties admin account) <> discloseMany' context.disclosures) $
      exerciseCmd offerCid accept with
        extraArgs = ExtraArgs with
          context = context.choiceContext
          meta = emptyMetadata

-- | Create an account if it doesn't already exist.
makeAccountIfMissing : AccountConfig -> Script ()
makeAccountIfMissing config = do
  let owner = fromSomeNote ("Unexpected special account: " <> show config.account) config.account.owner
  -- Create an AccountConfig contract as needed.
  forA_ config.account.provider $ \provider -> do
    accountConfigs <- queryFilter @AccountConfig owner (\ac -> ac.account == config.account)
    case accountConfigs of
      [(_, config')] -> assertMsg ("Account already exists with different config: " <> show config) (config' == config)
      [] -> do
        accountProposalCid <- submit provider do
          createCmd AccountConfig.AccountProposal with
            config
        submit owner do
          exerciseCmd accountProposalCid AccountConfig.AccountProposal_Accept
        pure ()
      accountConfigs -> abort $ T.unlines $
        ("Multiple accounts found for config: " <> show config) :: map show accountConfigs


-- V1 Token standard registry methods
-------------------------------------

registryApi_getTransferFactoryV1 : TestTokenV2Registry -> V1.TransferFactory_Transfer -> Script (EnrichedFactoryChoice factory V1.TransferFactory_Transfer)
registryApi_getTransferFactoryV1 registry transfer = do
  let v2Transfer = upcast transfer.transfer : V2.Transfer
  (tokenRulesCid, context, disclosures) <- getAccountMapAndTokenRulesC registry [v2Transfer.sender, v2Transfer.receiver]
  let
    transfer' =
      transfer with
        extraArgs.context = context

  pure EnrichedFactoryChoice with
    factoryCid = coerceContractId tokenRulesCid
    arg = transfer'
    disclosures

registryApi_getAllocationFactoryV1 : TestTokenV2Registry -> V1.AllocationFactory_Allocate -> Script (EnrichedFactoryChoice factory V1.AllocationFactory_Allocate)
registryApi_getAllocationFactoryV1 registry allocation = do
  let allocationV2 = upcast allocation.allocation : V2.AllocationSpecification
  (tokenRulesCid, context, disclosures) <- getAccountMapAndTokenRulesC registry [allocationV2.authorizer]
  let
    allocation' =
      allocation with
        extraArgs.context = context
  pure EnrichedFactoryChoice with
    factoryCid = coerceContractId tokenRulesCid
    arg = allocation'
    disclosures

registryApi_getTransferOfferContextV1 : TestTokenV2Registry -> ContractId V1.TransferInstruction -> Metadata -> Script OpenApiChoiceContext
registryApi_getTransferOfferContextV1 registry instrCid meta = do
  registryApi_getTransferOfferContextV2 registry (coerceContractId instrCid) meta

registryApi_getWithdrawContextV1
  : TestTokenV2Registry
  -> ContractId V1.Allocation
  -> Metadata
  -> Script OpenApiChoiceContext
registryApi_getWithdrawContextV1 registry cid meta = do
  registryApi_getWithdrawContextV2 registry (coerceContractId cid) meta

registryApi_getCancelContextV1
  : TestTokenV2Registry
  -> ContractId V1.Allocation
  -> Metadata
  -> Script OpenApiChoiceContext
registryApi_getCancelContextV1 registry cid meta = do
  registryApi_getCancelContextV2 registry (coerceContractId cid) meta

registryApi_getAllocationTransferContextV1
    : TestTokenV2Registry -> ContractId V1.Allocation -> Metadata -> Script OpenApiChoiceContext
registryApi_getAllocationTransferContextV1 registry cid _meta = do
  Some allocView <- queryInterfaceContractId @V1.Allocation registry.admin cid
  let v2Alloc = upcast allocView.allocation : V2.AllocationSpecification
  let v2TransferLegs = map (transferLegFromSide v2Alloc.authorizer) v2Alloc.transferLegSides
  let accounts = concatMap (\leg -> [leg.sender, leg.receiver]) v2TransferLegs
  (_tokenRulesCid, context, disclosures) <- getAccountMapAndTokenRulesC registry accounts
  lockedD <- getLockedTokensForAllocationsD registry (coerceContractId cid)
  pure OpenApiChoiceContext with
    disclosures = disclosures <> lockedD
    choiceContext = context


-- V2 Token standard registry methods
-------------------------------------

registryApi_getTransferFactoryV2 : TestTokenV2Registry -> V2.TransferFactory_Transfer -> Script (EnrichedFactoryChoice factory V2.TransferFactory_Transfer)
registryApi_getTransferFactoryV2 registry transfer = do
  (tokenRulesCid, context, disclosures) <- getAccountMapAndTokenRulesC registry [transfer.transfer.sender, transfer.transfer.receiver]
  let
    transfer' =
      transfer with
        extraArgs.context = context

  pure EnrichedFactoryChoice with
    factoryCid = coerceContractId tokenRulesCid
    arg = transfer'
    disclosures

registryApi_getAllocationFactoryV2 : TestTokenV2Registry -> V2.AllocationFactory_Allocate -> Script (EnrichedFactoryChoice factory V2.AllocationFactory_Allocate)
registryApi_getAllocationFactoryV2 registry allocation = do
  (tokenRulesCid, context, disclosures) <- getAccountMapAndTokenRulesC registry [allocation.allocation.authorizer]
  let
    allocation' =
      allocation with
        extraArgs.context = context
  pure EnrichedFactoryChoice with
    factoryCid = coerceContractId tokenRulesCid
    arg = allocation'
    disclosures

registryApi_getSettlementFactoryV2
  : TestTokenV2Registry
  -> V2.SettlementFactory_SettleBatch
  -> Script (EnrichedFactoryChoice V2.SettlementFactory V2.SettlementFactory_SettleBatch)
registryApi_getSettlementFactoryV2 registry arg = do
  let accounts = dedup $ concatMap (\leg -> [leg.sender, leg.receiver]) arg.transferLegs
  (tokenRulesCid, context, disclosures) <- getAccountMapAndTokenRulesC registry accounts
  lockedDs <- forA arg.allocations $ \alloc -> do
    getLockedTokensForAllocationsD registry alloc.allocationCid
  let
    arg' =
      arg with
        extraArgs.context = context

  pure EnrichedFactoryChoice with
    factoryCid = coerceContractId tokenRulesCid
    arg = arg'
    disclosures = disclosures <> mconcat lockedDs

registryApi_getTransferOfferContextV2 : TestTokenV2Registry -> ContractId V2.TransferInstruction -> Metadata -> Script OpenApiChoiceContext
registryApi_getTransferOfferContextV2 registry instrCid _meta = do
  Some instrView <- queryInterfaceContractId @V2.TransferInstruction registry.admin instrCid
  (_tokenRulesCid, context, disclosures) <- getAccountMapAndTokenRulesC registry [instrView.transfer.sender, instrView.transfer.receiver]
  lockedDs <- forA instrView.transfer.inputHoldingCids $ \holdingCid -> do
    let tokenCid = coerceContractId holdingCid : ContractId Token
    queryDisclosure' @Token registry.admin tokenCid
  pure OpenApiChoiceContext with
    disclosures = disclosures <> mconcat lockedDs
    choiceContext = context

registryApi_getAllocationInstructionContextV2 : TestTokenV2Registry -> ContractId V2.AllocationInstruction -> Metadata -> Script OpenApiChoiceContext
registryApi_getAllocationInstructionContextV2 registry instrCid _meta = do
  Some instrView <- queryInterfaceContractId @V2.AllocationInstruction registry.admin instrCid
  (_tokenRulesCid, choiceContext, disclosures) <- getAccountMapAndTokenRulesC registry [instrView.allocation.authorizer]
  pure OpenApiChoiceContext with
    disclosures
    choiceContext

registryApi_getWithdrawContextV2
  : TestTokenV2Registry
  -> ContractId V2.Allocation
  -> Metadata
  -> Script OpenApiChoiceContext
registryApi_getWithdrawContextV2 registry cid _meta = do
  Some allocView <- queryInterfaceContractId @V2.Allocation registry.admin cid
  (_tokenRulesCid, choiceContext, disclosures) <- getAccountMapAndTokenRulesC registry [allocView.allocation.authorizer]
  pure OpenApiChoiceContext with
    disclosures
    choiceContext

registryApi_getCancelContextV2
  : TestTokenV2Registry
  -> ContractId V2.Allocation
  -> Metadata
  -> Script OpenApiChoiceContext
registryApi_getCancelContextV2 registry cid _meta = do
  Some allocView <- queryInterfaceContractId @V2.Allocation registry.admin cid
  (_tokenRulesCid, choiceContext, disclosures) <- getAccountMapAndTokenRulesC registry [allocView.allocation.authorizer]
  lockedTokensD <- getLockedTokensForAllocationsD registry cid
  pure OpenApiChoiceContext with
    disclosures = disclosures <> lockedTokensD
    choiceContext = choiceContext


-- Shared context fetching utilities
------------------------------------

getTokenRules : TestTokenV2Registry -> Script (ContractId TestTokenV2.TokenRules, TestTokenV2.TokenRules)
getTokenRules registry = getTokenRules' registry.admin

getTokenRules' : Party -> Script (ContractId TestTokenV2.TokenRules, TestTokenV2.TokenRules)
getTokenRules' admin = do
  rules <- query @TestTokenV2.TokenRules admin
  case rules of
    [rule] -> return rule
    [] -> fail $ "No TestTokenV2Rules found: did you initialize the TestTokenV2 registry?"
    _ -> fail "Multiple TestTokenV2Rules found: are you initializing the TestTokenV2 registry multiple times?"

getLockedTokensForAllocationsD : TestTokenV2Registry -> ContractId V2.Allocation -> Script Disclosures'
getLockedTokensForAllocationsD registry allocCid = do
  Some allocView <- queryInterfaceContractId @V2.Allocation registry.admin allocCid
  discs <- forA allocView.holdingCids $ \holdingCid -> do
    let tokenCid = coerceContractId holdingCid : ContractId Token
    queryDisclosure' @Token registry.admin tokenCid
  pure $ mconcat discs

getAccountMapAndTokenRulesC
  : TestTokenV2Registry -> [V2.Account] -> Script (ContractId TokenRules, ChoiceContext, Disclosures')
getAccountMapAndTokenRulesC registry accounts = do
  (tokenRulesCid, _) <- getTokenRules registry
  tokenRulesD <- queryDisclosure' @TestTokenV2.TokenRules registry.admin tokenRulesCid
  accountConfigs <- catOptionals <$> forA accounts (getAccountConfig registry)
  let accountConfigsValue = AV_List (map (AV_ContractId . coerceContractId . fst) accountConfigs)
  let choiceContext = ChoiceContext with
        values = TextMap.fromList
          [ (accountConfigsContextKey, accountConfigsValue)
          , (tokenRulesContextKey, AV_ContractId (toAnyContractId tokenRulesCid))
          ]
  pure (tokenRulesCid, choiceContext, tokenRulesD <> foldMap snd accountConfigs)

getAccountConfig : TestTokenV2Registry -> V2.Account -> Script (Optional (ContractId AccountConfig.AccountConfig, Disclosures'))
getAccountConfig registry account = do
  result <- getAccountConfig' registry account
  case result of
    Some (cid, _config, disclosures) -> return (Some (cid, disclosures))
    None -> return None

getAccountConfig' : TestTokenV2Registry -> V2.Account -> Script (Optional (ContractId AccountConfig.AccountConfig, AccountConfig.AccountConfig, Disclosures'))
getAccountConfig' registry account = do
  cids <- queryFilter @AccountConfig.AccountConfig registry.admin (\config -> config.account == account)
  case cids of
    [(cid, config)] -> do
      disclosure <- queryDisclosure' @AccountConfig.AccountConfig registry.admin cid
      return (Some (cid, config, disclosure))
    [] -> return None
    _ -> abort ("More than one account config found for " <> (show account))
